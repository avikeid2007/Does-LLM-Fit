<Page
    x:Class="DoesLLMFit.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DoesLLMFit"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:um="using:Uno.Material"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="#FF0D1117">

    <Grid>
        <!--  Full-page background gradient  -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0.0" Color="#0D1117" />
                <GradientStop Offset="0.4" Color="#111927" />
                <GradientStop Offset="1.0" Color="#0D1117" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══ TOP BAR ═══  -->
        <!--
        <Border
            Grid.Row="0"
            Padding="10"
            Background="#0AFFFFFF">
            <Grid>
                <StackPanel
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="10">
                    <Image
                        Width="44"
                        VerticalAlignment="Center"
                        Source="ms-appx:///Assets/logo.png" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#88AABBCC">
                        <Run Text="Does" /><Run Foreground="#44A4FF" Text="LLM" /><Run Text="Fit" />
                    </TextBlock>
                </StackPanel>
        -->
        <!--  Right side: selected GPU label  -->
        <!--
                <TextBlock
                    x:Name="TopBarGpuLabel"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="#4490A0B0"
                    Text="" />
            </Grid>
        </Border>-->

        <ScrollViewer Grid.Row="1">
            <StackPanel HorizontalAlignment="Stretch" Spacing="0">

                <!--  ═══════════════════════════════════════════════  -->
                <!--  HERO HEADER  -->
                <!--  ═══════════════════════════════════════════════  -->
                <Border Padding="0,24,0,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Offset="0.0" Color="#0D1117" />
                            <GradientStop Offset="0.4" Color="#0F1D30" />
                            <GradientStop Offset="1.0" Color="#0A1628" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <StackPanel HorizontalAlignment="Center" Spacing="12">
                        <!--  Logo row  -->
                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="16">
                            <!--  App logo with glow ring  -->
                            <Grid Width="48" Height="48">

                                <Image
                                    Width="100"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Source="ms-appx:///Assets/logo.png" />
                                <!--<Border
                                    Width="42"
                                    Height="42"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    BorderBrush="#3044A4FF"
                                    BorderThickness="2"
                                    CornerRadius="21">

                                </Border>-->
                            </Grid>
                            <!--  App name  -->
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock
                                    FontSize="56"
                                    FontWeight="Bold"
                                    Foreground="#E8EDF3"
                                    Text="Does" />
                                <TextBlock
                                    Margin="6,0"
                                    FontSize="56"
                                    FontWeight="Bold"
                                    Foreground="#44A4FF"
                                    Text="LLM" />
                                <TextBlock
                                    FontSize="56"
                                    FontWeight="Bold"
                                    Foreground="#E8EDF3"
                                    Text="Fit?" />
                            </StackPanel>
                        </StackPanel>

                        <!--  Tagline  -->
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="14"
                            Foreground="#6690A0B0"
                            Text="Find the perfect local LLM for your hardware." />
                    </StackPanel>
                </Border>

                <!--  ═══════════════════════════════════════════════  -->
                <!--  HARDWARE INPUT CARD  -->
                <!--  ═══════════════════════════════════════════════  -->
                <Border
                    Margin="40,-16,40,0"
                    Padding="0"
                    Background="#FF151D2B"
                    BorderBrush="#18FFFFFF"
                    BorderThickness="1"
                    CornerRadius="24">

                    <!--  Inner glow accent at top  -->
                    <Grid>
                        <Border
                            Height="3"
                            VerticalAlignment="Top"
                            CornerRadius="24,24,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0.0" Color="#0044A4FF" />
                                    <GradientStop Offset="0.5" Color="#4044A4FF" />
                                    <GradientStop Offset="1.0" Color="#0044A4FF" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <StackPanel Padding="24,20,24,18" Spacing="14">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  Column 0: Apple Silicon Toggle  -->
                                <StackPanel
                                    Grid.Column="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                                    <Grid
                                        Width="100"
                                        Height="100"
                                        HorizontalAlignment="Center">
                                        <!--  Outer ring glow  -->
                                        <Border
                                            Width="100"
                                            Height="100"
                                            Background="#0844A4FF"
                                            CornerRadius="50" />
                                        <!--  Main ring  -->
                                        <Border
                                            Width="92"
                                            Height="92"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="#0844A4FF"
                                            BorderBrush="#44A4FF"
                                            BorderThickness="3"
                                            CornerRadius="46">
                                            <Viewbox
                                                Width="36"
                                                Height="36"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 22 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.09997 22C7.78997 22.05 6.79997 20.68 5.95997 19.47C4.24997 17 2.93997 12.45 4.69997 9.39C5.56997 7.87 7.12997 6.91 8.81997 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.09 16.67C20.06 16.74 19.67 18.11 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z" Fill="#44A4FF" />
                                                </Canvas>
                                            </Viewbox>
                                        </Border>
                                    </Grid>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="#CCE8EDF3"
                                        Text="Apple Silicon Mac" />
                                    <ToggleSwitch
                                        x:Name="AppleSiliconToggle"
                                        HorizontalAlignment="Center"
                                        OffContent="OFF"
                                        OnContent="ON"
                                        Toggled="AppleSiliconToggle_Toggled" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        Foreground="#4490A0B0"
                                        Text="Unified memory" />
                                </StackPanel>

                                <!--  Column 1: VRAM section with slider  -->
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="10">
                                    <!--  VRAM large number + GB suffix  -->
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="6">
                                        <TextBlock
                                            x:Name="VramDisplayText"
                                            VerticalAlignment="Bottom"
                                            FontSize="42"
                                            FontWeight="Bold"
                                            Foreground="#E8EDF3"
                                            Text="12" />
                                        <TextBlock
                                            Margin="0,0,0,8"
                                            VerticalAlignment="Bottom"
                                            FontSize="20"
                                            FontWeight="SemiBold"
                                            Foreground="#5590A0B0"
                                            Text="GB" />
                                    </StackPanel>

                                    <!--  VRAM Slider  -->
                                    <Grid>
                                        <!--  Custom track background  -->
                                        <Border
                                            Height="6"
                                            VerticalAlignment="Center"
                                            Background="#20FFFFFF"
                                            CornerRadius="3" />
                                        <Slider
                                            x:Name="VramSlider"
                                            Foreground="#44A4FF"
                                            Maximum="128"
                                            Minimum="0"
                                            StepFrequency="1"
                                            ValueChanged="VramSlider_ValueChanged"
                                            Value="12" />
                                    </Grid>

                                    <!--  VRAM detail text  -->
                                    <StackPanel HorizontalAlignment="Center" Spacing="3">
                                        <TextBlock
                                            x:Name="VramLabelText"
                                            HorizontalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="#8899AABB"
                                            Text="12 GB VRAM" />
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="6">
                                            <FontIcon
                                                VerticalAlignment="Center"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                FontSize="12"
                                                Foreground="#4490A0B0"
                                                Glyph="&#xE835;" />
                                            <TextBlock
                                                x:Name="VramTypeText"
                                                FontSize="11"
                                                Foreground="#4490A0B0"
                                                Text="Dedicated GPU VRAM" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!--  GPU ComboBox  -->
                                    <ComboBox
                                        x:Name="GpuComboBox"
                                        HorizontalAlignment="Stretch"
                                        PlaceholderText="Select GPU (auto-fills specs)..."
                                        SelectionChanged="GpuComboBox_SelectionChanged" />
                                </StackPanel>

                                <!--  Column 2: System RAM circular gauge  -->
                                <StackPanel
                                    Grid.Column="2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                                    <Grid
                                        Width="100"
                                        Height="100"
                                        HorizontalAlignment="Center">
                                        <!--  Outer ring glow  -->
                                        <Border
                                            Width="100"
                                            Height="100"
                                            Background="#0844A4FF"
                                            CornerRadius="50" />
                                        <!--  Main ring  -->
                                        <Border
                                            Width="92"
                                            Height="92"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="#0844A4FF"
                                            BorderBrush="#44A4FF"
                                            BorderThickness="3"
                                            CornerRadius="46">
                                            <TextBlock
                                                x:Name="RamDisplayText"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="32"
                                                FontWeight="Bold"
                                                Foreground="#E8EDF3"
                                                Text="32" />
                                        </Border>
                                    </Grid>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="6">
                                        <FontIcon
                                            VerticalAlignment="Center"
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            FontSize="12"
                                            Foreground="#5590A0B0"
                                            Glyph="&#xEDA2;" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="#5590A0B0"
                                            Text="System RAM (GB)" />
                                    </StackPanel>
                                    <muxc:NumberBox
                                        x:Name="RamBox"
                                        Width="120"
                                        HorizontalAlignment="Center"
                                        Maximum="1024"
                                        Minimum="1"
                                        SpinButtonPlacementMode="Compact"
                                        ValueChanged="RamBox_ValueChanged"
                                        Value="32" />
                                </StackPanel>
                            </Grid>

                            <!--  Advanced options row  -->
                            <Border
                                Padding="18,12"
                                Background="#0AFFFFFF"
                                CornerRadius="14">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition x:Name="UnifiedMemoryColumn" Width="0" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon
                                                VerticalAlignment="Center"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                FontSize="11"
                                                Foreground="#4490A0B0"
                                                Glyph="&#xE916;" />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="#5590A0B0"
                                                Text="Bandwidth (GB/s)" />
                                        </StackPanel>
                                        <muxc:NumberBox
                                            x:Name="BandwidthBox"
                                            MinHeight="32"
                                            HorizontalAlignment="Stretch"
                                            Maximum="10000"
                                            Minimum="0"
                                            SpinButtonPlacementMode="Compact"
                                            ValueChanged="BandwidthBox_ValueChanged"
                                            Value="0" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon
                                                VerticalAlignment="Center"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                FontSize="11"
                                                Foreground="#4490A0B0"
                                                Glyph="&#xE8C8;" />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="#5590A0B0"
                                                Text="Context Length" />
                                        </StackPanel>
                                        <ComboBox
                                            x:Name="ContextComboBox"
                                            MinHeight="32"
                                            HorizontalAlignment="Stretch"
                                            SelectionChanged="ContextComboBox_SelectionChanged">
                                            <ComboBoxItem Content="2K" Tag="2048" />
                                            <ComboBoxItem
                                                Content="4K"
                                                IsSelected="True"
                                                Tag="4096" />
                                            <ComboBoxItem Content="8K" Tag="8192" />
                                            <ComboBoxItem Content="16K" Tag="16384" />
                                            <ComboBoxItem Content="32K" Tag="32768" />
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel
                                        x:Name="UnifiedMemoryPanel"
                                        Grid.Column="2"
                                        Spacing="4"
                                        Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon
                                                VerticalAlignment="Center"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                FontSize="11"
                                                Foreground="#4490A0B0"
                                                Glyph="&#xE946;" />
                                            <TextBlock FontSize="11" Foreground="#5590A0B0">
                                                <Run Text="Inference Memory " />
                                                <Run x:Name="UnifiedMemoryPercentText" Text="(75%)" />
                                            </TextBlock>
                                        </StackPanel>
                                        <Slider
                                            x:Name="UnifiedMemorySlider"
                                            HorizontalAlignment="Stretch"
                                            Maximum="95"
                                            Minimum="25"
                                            StepFrequency="5"
                                            ValueChanged="UnifiedMemorySlider_ValueChanged"
                                            Value="75" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  ═══════════════════════════════════════════════  -->
                <!--  "Does It Fit?" CTA Button  -->
                <!--  ═══════════════════════════════════════════════  -->
                <Button
                    x:Name="CheckButton"
                    Margin="0,18,0,0"
                    Padding="52,16"
                    HorizontalAlignment="Center"
                    Click="CheckButton_Click"
                    CornerRadius="28">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0.0" Color="#1976D2" />
                            <GradientStop Offset="0.5" Color="#42A5F5" />
                            <GradientStop Offset="1.0" Color="#1976D2" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            FontSize="18"
                            Foreground="White"
                            Glyph="&#xE9D9;" />
                        <TextBlock
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Does LLM Fit?" />
                    </StackPanel>
                </Button>

                <!--  ═══════════════════════════════════════════════  -->
                <!--  STATUS SUMMARY (hidden until results)  -->
                <!--  ═══════════════════════════════════════════════  -->
                <StackPanel
                    x:Name="SummaryPanel"
                    Margin="32,18,32,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="14"
                    Visibility="Collapsed">
                    <!--  Green  -->
                    <Border
                        MinWidth="140"
                        Padding="24,14"
                        Background="#104CAF50"
                        BorderBrush="#254CAF50"
                        BorderThickness="1"
                        CornerRadius="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Grid.Column="0"
                                Width="36"
                                Height="36"
                                VerticalAlignment="Center"
                                Background="#184CAF50"
                                CornerRadius="18">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="16"
                                    Foreground="#4CAF50"
                                    Glyph="&#xE73E;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="0">
                                <TextBlock
                                    x:Name="GreenCountText"
                                    FontSize="26"
                                    FontWeight="Bold"
                                    Foreground="#4CAF50"
                                    Text="0" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#664CAF50"
                                    Text="Runs Great" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!--  Yellow  -->
                    <Border
                        MinWidth="140"
                        Padding="24,14"
                        Background="#10FFC107"
                        BorderBrush="#25FFC107"
                        BorderThickness="1"
                        CornerRadius="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Grid.Column="0"
                                Width="36"
                                Height="36"
                                VerticalAlignment="Center"
                                Background="#18FFC107"
                                CornerRadius="18">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="16"
                                    Foreground="#FFC107"
                                    Glyph="&#xE7BA;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="0">
                                <TextBlock
                                    x:Name="YellowCountText"
                                    FontSize="26"
                                    FontWeight="Bold"
                                    Foreground="#FFC107"
                                    Text="0" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#66FFC107"
                                    Text="Tight Fit" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!--  Red  -->
                    <Border
                        MinWidth="140"
                        Padding="24,14"
                        Background="#10F44336"
                        BorderBrush="#25F44336"
                        BorderThickness="1"
                        CornerRadius="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Grid.Column="0"
                                Width="36"
                                Height="36"
                                VerticalAlignment="Center"
                                Background="#18F44336"
                                CornerRadius="18">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="16"
                                    Foreground="#F44336"
                                    Glyph="&#xE711;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="0">
                                <TextBlock
                                    x:Name="RedCountText"
                                    FontSize="26"
                                    FontWeight="Bold"
                                    Foreground="#F44336"
                                    Text="0" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#66F44336"
                                    Text="Won't Fit" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!--  ═══════════════════════════════════════════════  -->
                <!--  SECTION HEADER for results  -->
                <!--  ═══════════════════════════════════════════════  -->
                <StackPanel
                    x:Name="ResultsHeader"
                    Margin="44,14,44,0"
                    Orientation="Horizontal"
                    Spacing="8"
                    Visibility="Collapsed">
                    <Border
                        Width="4"
                        Height="18"
                        VerticalAlignment="Center"
                        Background="#44A4FF"
                        CornerRadius="2" />
                    <TextBlock
                        x:Name="ResultsHeaderText"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="#8899AABB"
                        Text="Model Results" />
                    <TextBlock
                        x:Name="ResultsCountText"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#4490A0B0"
                        Text="" />
                </StackPanel>

                <!--  ═══════════════════════════════════════════════  -->
                <!--  MODEL RESULT CARDS (horizontal scroll)  -->
                <!--  ═══════════════════════════════════════════════  -->
                <ScrollViewer
                    x:Name="ModelCardsScroller"
                    Margin="0,10,0,24"
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    Visibility="Collapsed">
                    <StackPanel
                        x:Name="ModelCardsPanel"
                        Padding="40,0,40,12"
                        Orientation="Horizontal"
                        Spacing="16" />
                </ScrollViewer>

                <!--  Empty state  -->
                <StackPanel
                    x:Name="EmptyHint"
                    Margin="0,40,0,60"
                    HorizontalAlignment="Center"
                    Spacing="12">
                    <FontIcon
                        HorizontalAlignment="Center"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="44"
                        Foreground="#2290A0B0"
                        Glyph="&#xE946;" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="14"
                        Foreground="#3390A0B0"
                        Text="Configure your hardware above and tap 'Does LLM Fit?'" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="12"
                        Foreground="#2290A0B0"
                        Text="We'll check 36 popular LLMs against your specs" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
