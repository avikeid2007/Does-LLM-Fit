<Page x:Class="DoesLLMFit.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:DoesLLMFit"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      Background="#FF0D1117">

  <Grid>
    <!-- Full-page background gradient -->
    <Grid.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0D1117" Offset="0.0" />
        <GradientStop Color="#111927" Offset="0.4" />
        <GradientStop Color="#0D1117" Offset="1.0" />
      </LinearGradientBrush>
    </Grid.Background>

    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- ═══ TOP BAR ═══ -->
    <Border Grid.Row="0" Padding="10" Background="#0AFFFFFF">
      <Grid>
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <FontIcon Glyph="&#xE950;" FontSize="16"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Foreground="#44A4FF" VerticalAlignment="Center" />
          <TextBlock FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                     Foreground="#88AABBCC">
            <Run Text="Does" /><Run Text="LLM" Foreground="#44A4FF" /><Run Text="Fit" />
          </TextBlock>
        </StackPanel>
        <!-- Right side: selected GPU label -->
        <TextBlock x:Name="TopBarGpuLabel"
                   Text=""
                   FontSize="12" Foreground="#4490A0B0"
                   HorizontalAlignment="Right" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="0" HorizontalAlignment="Stretch">

        <!-- ═══════════════════════════════════════════════ -->
        <!-- HERO HEADER -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Padding="0,24,0,20">
          <Border.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
              <GradientStop Color="#0D1117" Offset="0.0" />
              <GradientStop Color="#0F1D30" Offset="0.4" />
              <GradientStop Color="#0A1628" Offset="1.0" />
            </LinearGradientBrush>
          </Border.Background>

          <StackPanel HorizontalAlignment="Center" Spacing="12">
            <!-- Logo row -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
              <!-- Gear-brain icon with glow ring -->
              <Grid Width="48" Height="48">
                <Border Width="48" Height="48" CornerRadius="24"
                        Background="#1244A4FF" />
                <Border Width="42" Height="42" CornerRadius="21"
                        BorderBrush="#3044A4FF" BorderThickness="2"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                  <FontIcon Glyph="&#xE950;" FontSize="20"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            Foreground="#44A4FF"
                            HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </Grid>
              <!-- App name -->
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Does" FontSize="36" FontWeight="Bold" Foreground="#E8EDF3" />
                <TextBlock Text="LLM" FontSize="36" FontWeight="Bold" Foreground="#44A4FF" Margin="6,0" />
                <TextBlock Text="Fit?" FontSize="36" FontWeight="Bold" Foreground="#E8EDF3" />
              </StackPanel>
            </StackPanel>

            <!-- Tagline -->
            <TextBlock Text="Find the perfect local LLM for your hardware."
                       FontSize="14" Foreground="#6690A0B0"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- HARDWARE INPUT CARD -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Margin="40,-16,40,0" Padding="0"
                CornerRadius="24"
                Background="#FF151D2B"
                BorderBrush="#18FFFFFF" BorderThickness="1">

          <!-- Inner glow accent at top -->
          <Grid>
            <Border Height="3" VerticalAlignment="Top"
                    CornerRadius="24,24,0,0">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                  <GradientStop Color="#0044A4FF" Offset="0.0" />
                  <GradientStop Color="#4044A4FF" Offset="0.5" />
                  <GradientStop Color="#0044A4FF" Offset="1.0" />
                </LinearGradientBrush>
              </Border.Background>
            </Border>

            <StackPanel Padding="24,20,24,18" Spacing="14">
              <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="1.5*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Column 0: Apple Silicon Toggle -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="8"
                            VerticalAlignment="Center">
                  <Grid Width="100" Height="100" HorizontalAlignment="Center">
                    <!-- Outer ring glow -->
                    <Border Width="100" Height="100" CornerRadius="50"
                            Background="#0844A4FF" />
                    <!-- Main ring -->
                    <Border Width="92" Height="92" CornerRadius="46"
                            BorderBrush="#44A4FF" BorderThickness="3"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#0844A4FF">
                      <Viewbox Width="36" Height="36"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                          <Path Fill="#44A4FF"
                                Data="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 22 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.09997 22C7.78997 22.05 6.79997 20.68 5.95997 19.47C4.24997 17 2.93997 12.45 4.69997 9.39C5.56997 7.87 7.12997 6.91 8.81997 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.09 16.67C20.06 16.74 19.67 18.11 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z" />
                        </Canvas>
                      </Viewbox>
                    </Border>
                  </Grid>
                  <TextBlock Text="Apple Silicon Mac"
                             FontSize="13" FontWeight="SemiBold"
                             Foreground="#CCE8EDF3"
                             HorizontalAlignment="Center" />
                  <ToggleSwitch x:Name="AppleSiliconToggle"
                                OnContent="ON" OffContent="OFF"
                                HorizontalAlignment="Center"
                                Toggled="AppleSiliconToggle_Toggled" />
                  <TextBlock Text="Unified memory"
                             FontSize="11" Foreground="#4490A0B0"
                             HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Column 1: VRAM section with slider -->
                <StackPanel Grid.Column="1" Spacing="10"
                            VerticalAlignment="Center">
                  <!-- VRAM large number + GB suffix -->
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                              Spacing="6">
                    <TextBlock x:Name="VramDisplayText" Text="12"
                               FontSize="42" FontWeight="Bold"
                               Foreground="#E8EDF3"
                               VerticalAlignment="Bottom" />
                    <TextBlock Text="GB"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="#5590A0B0"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,8" />
                  </StackPanel>

                  <!-- VRAM Slider -->
                  <Grid>
                    <!-- Custom track background -->
                    <Border Height="6" CornerRadius="3" VerticalAlignment="Center"
                            Background="#20FFFFFF" />
                    <Slider x:Name="VramSlider"
                            Minimum="0" Maximum="128" Value="12"
                            StepFrequency="1"
                            Foreground="#44A4FF"
                            ValueChanged="VramSlider_ValueChanged" />
                  </Grid>

                  <!-- VRAM detail text -->
                  <StackPanel HorizontalAlignment="Center" Spacing="3">
                    <TextBlock x:Name="VramLabelText" Text="12 GB VRAM"
                               FontSize="14" FontWeight="SemiBold" Foreground="#8899AABB"
                               HorizontalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                      <FontIcon Glyph="&#xE835;" FontSize="12"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Foreground="#4490A0B0" VerticalAlignment="Center" />
                      <TextBlock x:Name="VramTypeText" Text="Dedicated GPU VRAM"
                                 FontSize="11" Foreground="#4490A0B0" />
                    </StackPanel>
                  </StackPanel>

                  <!-- GPU ComboBox -->
                  <ComboBox x:Name="GpuComboBox"
                            PlaceholderText="Select GPU (auto-fills specs)..."
                            HorizontalAlignment="Stretch"
                            SelectionChanged="GpuComboBox_SelectionChanged" />
                </StackPanel>

                <!-- Column 2: System RAM circular gauge -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="8"
                            VerticalAlignment="Center">
                  <Grid Width="100" Height="100" HorizontalAlignment="Center">
                    <!-- Outer ring glow -->
                    <Border Width="100" Height="100" CornerRadius="50"
                            Background="#0844A4FF" />
                    <!-- Main ring -->
                    <Border Width="92" Height="92" CornerRadius="46"
                            BorderBrush="#44A4FF" BorderThickness="3"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#0844A4FF">
                      <TextBlock x:Name="RamDisplayText" Text="32"
                                 FontSize="32" FontWeight="Bold"
                                 Foreground="#E8EDF3"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                  </Grid>
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                    <FontIcon Glyph="&#xEDA2;" FontSize="12"
                              FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              Foreground="#5590A0B0" VerticalAlignment="Center" />
                    <TextBlock Text="System RAM (GB)"
                               FontSize="12" Foreground="#5590A0B0"
                               VerticalAlignment="Center" />
                  </StackPanel>
                  <muxc:NumberBox x:Name="RamBox" Value="32"
                                  Minimum="1" Maximum="1024"
                                  SpinButtonPlacementMode="Compact"
                                  Width="120" HorizontalAlignment="Center"
                                  ValueChanged="RamBox_ValueChanged" />
                </StackPanel>
              </Grid>

              <!-- Advanced options row -->
              <Border CornerRadius="14" Padding="18,12"
                      Background="#0AFFFFFF">
                <Grid ColumnSpacing="16">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="UnifiedMemoryColumn" Width="0" />
                  </Grid.ColumnDefinitions>

                  <StackPanel Grid.Column="0" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <FontIcon Glyph="&#xE916;" FontSize="11"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Foreground="#4490A0B0" VerticalAlignment="Center" />
                      <TextBlock Text="Bandwidth (GB/s)" FontSize="11" Foreground="#5590A0B0" />
                    </StackPanel>
                    <muxc:NumberBox x:Name="BandwidthBox" Value="0"
                                    Minimum="0" Maximum="10000"
                                    SpinButtonPlacementMode="Compact"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="32"
                                    ValueChanged="BandwidthBox_ValueChanged" />
                  </StackPanel>

                  <StackPanel Grid.Column="1" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <FontIcon Glyph="&#xE8C8;" FontSize="11"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Foreground="#4490A0B0" VerticalAlignment="Center" />
                      <TextBlock Text="Context Length" FontSize="11" Foreground="#5590A0B0" />
                    </StackPanel>
                    <ComboBox x:Name="ContextComboBox"
                              HorizontalAlignment="Stretch"
                              MinHeight="32"
                              SelectionChanged="ContextComboBox_SelectionChanged">
                      <ComboBoxItem Content="2K" Tag="2048" />
                      <ComboBoxItem Content="4K" Tag="4096" IsSelected="True" />
                      <ComboBoxItem Content="8K" Tag="8192" />
                      <ComboBoxItem Content="16K" Tag="16384" />
                      <ComboBoxItem Content="32K" Tag="32768" />
                    </ComboBox>
                  </StackPanel>

                  <StackPanel Grid.Column="2" Spacing="4"
                              x:Name="UnifiedMemoryPanel" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <FontIcon Glyph="&#xE946;" FontSize="11"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Foreground="#4490A0B0" VerticalAlignment="Center" />
                      <TextBlock FontSize="11" Foreground="#5590A0B0">
                        <Run Text="Inference Memory " />
                        <Run x:Name="UnifiedMemoryPercentText" Text="(75%)" />
                      </TextBlock>
                    </StackPanel>
                    <Slider x:Name="UnifiedMemorySlider"
                            Minimum="25" Maximum="95" Value="75"
                            StepFrequency="5"
                            HorizontalAlignment="Stretch"
                            ValueChanged="UnifiedMemorySlider_ValueChanged" />
                  </StackPanel>
                </Grid>
              </Border>
            </StackPanel>
          </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- "Does It Fit?" CTA Button -->
        <!-- ═══════════════════════════════════════════════ -->
        <Button x:Name="CheckButton"
                HorizontalAlignment="Center"
                Margin="0,18,0,0"
                Padding="52,16"
                CornerRadius="28"
                Click="CheckButton_Click">
          <Button.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
              <GradientStop Color="#1976D2" Offset="0.0" />
              <GradientStop Color="#42A5F5" Offset="0.5" />
              <GradientStop Color="#1976D2" Offset="1.0" />
            </LinearGradientBrush>
          </Button.Background>
          <StackPanel Orientation="Horizontal" Spacing="10">
            <FontIcon Glyph="&#xE9D9;" FontSize="18"
                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Foreground="White" />
            <TextBlock Text="Does LLM Fit?"
                       FontSize="18" FontWeight="Bold"
                       Foreground="White" />
          </StackPanel>
        </Button>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- STATUS SUMMARY (hidden until results) -->
        <!-- ═══════════════════════════════════════════════ -->
        <StackPanel x:Name="SummaryPanel" Visibility="Collapsed"
                    Orientation="Horizontal" Spacing="14"
                    HorizontalAlignment="Center"
                    Margin="32,18,32,0">
          <!-- Green -->
          <Border CornerRadius="16" Padding="24,14"
                  Background="#104CAF50" BorderBrush="#254CAF50" BorderThickness="1"
                  MinWidth="140">
            <Grid ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                      Background="#184CAF50" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE73E;" FontSize="16" Foreground="#4CAF50"
                          FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <StackPanel Grid.Column="1" Spacing="0">
                <TextBlock x:Name="GreenCountText" Text="0"
                           FontSize="26" FontWeight="Bold" Foreground="#4CAF50" />
                <TextBlock Text="Runs Great" FontSize="11" Foreground="#664CAF50" />
              </StackPanel>
            </Grid>
          </Border>
          <!-- Yellow -->
          <Border CornerRadius="16" Padding="24,14"
                  Background="#10FFC107" BorderBrush="#25FFC107" BorderThickness="1"
                  MinWidth="140">
            <Grid ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                      Background="#18FFC107" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE7BA;" FontSize="16" Foreground="#FFC107"
                          FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <StackPanel Grid.Column="1" Spacing="0">
                <TextBlock x:Name="YellowCountText" Text="0"
                           FontSize="26" FontWeight="Bold" Foreground="#FFC107" />
                <TextBlock Text="Tight Fit" FontSize="11" Foreground="#66FFC107" />
              </StackPanel>
            </Grid>
          </Border>
          <!-- Red -->
          <Border CornerRadius="16" Padding="24,14"
                  Background="#10F44336" BorderBrush="#25F44336" BorderThickness="1"
                  MinWidth="140">
            <Grid ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                      Background="#18F44336" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE711;" FontSize="16" Foreground="#F44336"
                          FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <StackPanel Grid.Column="1" Spacing="0">
                <TextBlock x:Name="RedCountText" Text="0"
                           FontSize="26" FontWeight="Bold" Foreground="#F44336" />
                <TextBlock Text="Won't Fit" FontSize="11" Foreground="#66F44336" />
              </StackPanel>
            </Grid>
          </Border>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- SECTION HEADER for results -->
        <!-- ═══════════════════════════════════════════════ -->
        <StackPanel x:Name="ResultsHeader" Visibility="Collapsed"
                    Orientation="Horizontal" Spacing="8"
                    Margin="44,14,44,0">
          <Border Width="4" Height="18" CornerRadius="2"
                  Background="#44A4FF" VerticalAlignment="Center" />
          <TextBlock x:Name="ResultsHeaderText" Text="Model Results"
                     FontSize="16" FontWeight="SemiBold"
                     Foreground="#8899AABB" VerticalAlignment="Center" />
          <TextBlock x:Name="ResultsCountText" Text=""
                     FontSize="13" Foreground="#4490A0B0"
                     VerticalAlignment="Center" Margin="8,0,0,0" />
        </StackPanel>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- MODEL RESULT CARDS (horizontal scroll) -->
        <!-- ═══════════════════════════════════════════════ -->
        <ScrollViewer x:Name="ModelCardsScroller"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      HorizontalScrollMode="Enabled"
                      Margin="0,10,0,24"
                      Visibility="Collapsed">
          <StackPanel x:Name="ModelCardsPanel"
                      Orientation="Horizontal"
                      Spacing="16"
                      Padding="40,0,40,12" />
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel x:Name="EmptyHint"
                    HorizontalAlignment="Center"
                    Margin="0,40,0,60"
                    Spacing="12">
          <FontIcon Glyph="&#xE946;" FontSize="44"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Foreground="#2290A0B0"
                    HorizontalAlignment="Center" />
          <TextBlock Text="Configure your hardware above and tap 'Does LLM Fit?'"
                     FontSize="14" Foreground="#3390A0B0"
                     HorizontalAlignment="Center" />
          <TextBlock Text="We'll check 36 popular LLMs against your specs"
                     FontSize="12" Foreground="#2290A0B0"
                     HorizontalAlignment="Center" />
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</Page>
