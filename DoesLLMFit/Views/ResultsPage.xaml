<Page x:Class="DoesLLMFit.Views.ResultsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      Background="{ThemeResource BackgroundBrush}">

  <Grid Padding="32,28,32,24" RowSpacing="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Spacing="6">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE9D9;" FontSize="28"
                  FontFamily="{ThemeResource SymbolThemeFontFamily}"
                  Foreground="{ThemeResource PrimaryBrush}"
                  VerticalAlignment="Center" />
        <TextBlock Text="Compatibility Results"
                   Style="{ThemeResource TitleLargeTextBlockStyle}"
                   VerticalAlignment="Center" />
      </StackPanel>
      <TextBlock x:Name="HardwareSummaryText"
                 Style="{ThemeResource CaptionTextBlockStyle}"
                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                 Margin="40,0,0,0" />
    </StackPanel>

    <!-- Summary Cards -->
    <Grid Grid.Row="1" ColumnSpacing="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Green Card -->
      <Border Grid.Column="0" CornerRadius="16" Padding="20,16"
              Background="#124CAF50" BorderBrush="#304CAF50" BorderThickness="1">
        <Grid ColumnSpacing="14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                  Background="#204CAF50" VerticalAlignment="Center">
            <FontIcon Glyph="&#xE73E;" FontSize="18" Foreground="#4CAF50"
                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock x:Name="GreenCountText" Text="0"
                       FontSize="26" FontWeight="Bold" Foreground="#4CAF50" />
            <TextBlock Text="Runs Great" FontSize="12"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Yellow Card -->
      <Border Grid.Column="1" CornerRadius="16" Padding="20,16"
              Background="#12FFC107" BorderBrush="#30FFC107" BorderThickness="1">
        <Grid ColumnSpacing="14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                  Background="#20FFC107" VerticalAlignment="Center">
            <FontIcon Glyph="&#xE7BA;" FontSize="18" Foreground="#FFC107"
                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock x:Name="YellowCountText" Text="0"
                       FontSize="26" FontWeight="Bold" Foreground="#FFC107" />
            <TextBlock Text="Tight Fit" FontSize="12"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Red Card -->
      <Border Grid.Column="2" CornerRadius="16" Padding="20,16"
              Background="#12F44336" BorderBrush="#30F44336" BorderThickness="1">
        <Grid ColumnSpacing="14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                  Background="#20F44336" VerticalAlignment="Center">
            <FontIcon Glyph="&#xE711;" FontSize="18" Foreground="#F44336"
                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock x:Name="RedCountText" Text="0"
                       FontSize="26" FontWeight="Bold" Foreground="#F44336" />
            <TextBlock Text="Won't Fit" FontSize="12"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <!-- Filters -->
    <Border Grid.Row="2" CornerRadius="12" Padding="16,12"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="1">
      <Grid ColumnSpacing="16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE71C;" FontSize="14"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Foreground="{ThemeResource OnSurfaceVariantBrush}"
                    VerticalAlignment="Center" Margin="0,0,4,0" />
          <Button x:Name="FilterAll" Content="All"
                  Click="FilterStatus_Click" Tag="All"
                  Style="{ThemeResource FilledTonalButtonStyle}"
                  Padding="14,6" />
          <Button x:Name="FilterGreen" Click="FilterStatus_Click" Tag="Green"
                  Padding="14,6">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="8" Height="8" Fill="#4CAF50" VerticalAlignment="Center" />
              <TextBlock Text="Runs Great" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button x:Name="FilterYellow" Click="FilterStatus_Click" Tag="Yellow"
                  Padding="14,6">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="8" Height="8" Fill="#FFC107" VerticalAlignment="Center" />
              <TextBlock Text="Tight Fit" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button x:Name="FilterRed" Click="FilterStatus_Click" Tag="Red"
                  Padding="14,6">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="8" Height="8" Fill="#F44336" VerticalAlignment="Center" />
              <TextBlock Text="Won't Fit" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE8CB;" FontSize="14"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Foreground="{ThemeResource OnSurfaceVariantBrush}"
                    VerticalAlignment="Center" />
          <ComboBox x:Name="CategoryFilter"
                    PlaceholderText="All Categories"
                    MinWidth="160"
                    SelectionChanged="CategoryFilter_SelectionChanged" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Results List -->
    <ScrollViewer Grid.Row="3">
      <StackPanel x:Name="ResultsPanel" Spacing="8" />
    </ScrollViewer>

    <!-- Empty state -->
    <StackPanel x:Name="EmptyState"
                Grid.Row="3"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="Visible">
      <FontIcon Glyph="&#xE946;" FontSize="48"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                Foreground="{ThemeResource OnSurfaceVariantBrush}"
                HorizontalAlignment="Center"
                Opacity="0.4" />
      <TextBlock Text="No results yet"
                 Style="{ThemeResource SubtitleTextBlockStyle}"
                 HorizontalAlignment="Center"
                 Foreground="{ThemeResource OnSurfaceVariantBrush}" />
      <TextBlock Text="Go to Hardware Setup and click 'Check Compatibility'"
                 Style="{ThemeResource CaptionTextBlockStyle}"
                 HorizontalAlignment="Center"
                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                 Opacity="0.6" />
    </StackPanel>

  </Grid>
</Page>
