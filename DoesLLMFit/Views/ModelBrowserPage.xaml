<Page x:Class="DoesLLMFit.Views.ModelBrowserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      Background="{ThemeResource BackgroundBrush}">

  <Grid Padding="32,28,32,24" RowSpacing="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Spacing="6">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <FontIcon Glyph="&#xE8A9;" FontSize="28"
                  FontFamily="{ThemeResource SymbolThemeFontFamily}"
                  Foreground="{ThemeResource PrimaryBrush}"
                  VerticalAlignment="Center" />
        <TextBlock Text="Model Browser"
                   Style="{ThemeResource TitleLargeTextBlockStyle}"
                   VerticalAlignment="Center" />
      </StackPanel>
      <TextBlock Text="Explore curated open-source LLMs. Click any model for details."
                 Style="{ThemeResource CaptionTextBlockStyle}"
                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                 Margin="40,0,0,0" />
    </StackPanel>

    <!-- Search & Filter Bar -->
    <Border Grid.Row="1" CornerRadius="12" Padding="16,12"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="1">
      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <FontIcon Glyph="&#xE721;" FontSize="16"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Foreground="{ThemeResource OnSurfaceVariantBrush}"
                    VerticalAlignment="Center"
                    Margin="0,0,10,0" />
          <TextBox x:Name="SearchBox"
                   PlaceholderText="Search models by name..."
                   Grid.Column="1"
                   TextChanged="SearchBox_TextChanged"
                   BorderThickness="0"
                   Background="Transparent" />
        </Grid>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE8CB;" FontSize="14"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Foreground="{ThemeResource OnSurfaceVariantBrush}"
                    VerticalAlignment="Center" />
          <ComboBox x:Name="CategoryComboBox"
                    PlaceholderText="All Categories"
                    MinWidth="180"
                    SelectionChanged="CategoryComboBox_SelectionChanged" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Model Cards -->
    <ScrollViewer Grid.Row="2">
      <muxc:ItemsRepeater x:Name="ModelRepeater">
        <muxc:ItemsRepeater.Layout>
          <muxc:UniformGridLayout MinItemWidth="320"
                                   MinColumnSpacing="16"
                                   MinRowSpacing="16"
                                   ItemsStretch="Fill" />
        </muxc:ItemsRepeater.Layout>
      </muxc:ItemsRepeater>
    </ScrollViewer>

  </Grid>
</Page>
