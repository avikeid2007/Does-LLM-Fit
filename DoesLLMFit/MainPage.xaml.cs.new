using DoesLLMFit.ViewModels;
using Microsoft.UI.Xaml.Controls;
using Microsoft.UI.Xaml.Markup;
using Windows.UI;

namespace DoesLLMFit;

public sealed partial class MainPage : Page
{
    public MainPageViewModel ViewModel { get; }

    private bool _initialized;

    public MainPage()
    {
        ViewModel = App.Services.GetRequiredService<MainPageViewModel>();
        this.InitializeComponent();
        Loaded += MainPage_Loaded;

        // GPU ComboBox needs brand SVG icons built in code-behind (XamlReader.Load)
        ViewModel.GpuItems.CollectionChanged += (_, _) => PopulateGpuComboBox();
        ViewModel.PropertyChanged += (_, e) =>
        {
            if (e.PropertyName == nameof(ViewModel.SelectedGpu))
                SyncGpuComboBoxSelection();
        };
    }

    private async void MainPage_Loaded(object sender, RoutedEventArgs e)
    {
        if (_initialized) return;
        _initialized = true;
        await ViewModel.InitializeAsync();
    }

    // ─── GPU Brand Icons (requires XamlReader.Load, can't be done in pure binding) ──

